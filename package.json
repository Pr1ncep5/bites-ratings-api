{
  "name": "bites-ratings",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun --cwd apps/api dev",
    "dev:web": "bun --cwd apps/web dev",
    "build": "bun run --filter '*' build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
